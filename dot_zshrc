eval "$(starship init zsh)"

# Use ls from coreutils for GNU flavor
alias ls='gls -lhF --group-directories-first --color=auto'

# Use emacsclient for Emacs.  On macOS, Homebrew starts the emacs-plus service
# at launch.
# alias emacs='/opt/homebrew/opt/emacs-plus@31/bin/emacsclient -c'
export VISUAL="emacsclient -c -nw"

export PATH=$PATH:$HOME/ledger/
export PATH=$PATH:/Applications/MATLAB_R2024b.app/bin
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init - zsh)"
eval "$(pyenv virtualenv-init -)"
